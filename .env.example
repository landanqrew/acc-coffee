# Neon Postgres connection string (pooled endpoint)
DATABASE_URL=

# Resend API key — used for magic-link sign-in and Restock Alerts
RESEND_API_KEY=

# From address for all outgoing email (must be a verified domain/sender in Resend)
EMAIL_FROM=

# Shared secret guarding the /api/test-email route (walking-skeleton only)
TEST_EMAIL_SECRET=

# Auth.js session/token signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical app URL for magic-link callbacks (e.g. https://acc-coffee.vercel.app).
# Optional locally; Auth.js infers it in development.
AUTH_URL=

# Bootstrap the first Lead: this email may sign in with no invite and is made a
# Lead on first sign-in, so the team isn't locked out on day one.
BOOTSTRAP_LEAD_EMAIL=
